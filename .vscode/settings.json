{
  "search.exclude": {
    "out": true,
    "dist": true,
    "node_modules": true,
    "**/*.map": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "cSpell.words": ["oxfmt", "oxlint", "tsgolint", "esbuild", "oxfmtrc", "oxlintrc"]
}
